<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardBackgroundColor="@color/card_white"
    app:cardCornerRadius="22dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="28dp">

        <ImageView
            android:id="@+id/imageNotificationDialogIcon"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/bg_circle_gray"
            android:padding="30dp"
            android:src="@drawable/ic_notif"
            app:tint="@color/brown_text" />

        <TextView
            android:id="@+id/textNotificationDialogMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:fontFamily="@font/poppins_semi_bold"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:textColor="@color/brown_text"
            android:textSize="20sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:gravity="center"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonOpenNotification"
                android:layout_width="132dp"
                android:layout_height="52dp"
                android:fontFamily="@font/poppins_semi_bold"
                android:text="OPEN"
                android:textColor="@color/card_white"
                android:textSize="14sp"
                app:backgroundTint="@color/red_primary"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonCloseNotification"
                android:layout_width="132dp"
                android:layout_height="52dp"
                android:layout_marginStart="18dp"
                android:fontFamily="@font/poppins_semi_bold"
                android:text="CLOSE"
                android:textColor="@color/brown_text"
                android:textSize="14sp"
                app:backgroundTint="#EADFD8"
                app:cornerRadius="24dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
