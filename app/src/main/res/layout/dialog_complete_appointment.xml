<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardBackgroundColor="@color/card_white"
    app:cardCornerRadius="18dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_extra_bold"
            android:text="Complete Appointment"
            android:textColor="@color/brown_text"
            android:textSize="22sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/poppins_semi_bold"
            android:text="Consultation note"
            android:textColor="@color/brown_text"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/editConsultationNote"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:fontFamily="@font/poppins_regular"
            android:gravity="top"
            android:inputType="textCapSentences|textMultiLine"
            android:padding="14dp"
            android:textColor="@color/brown_text"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSubmitComplete"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginStart="36dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="36dp"
            android:fontFamily="@font/poppins_semi_bold"
            android:text="SUBMIT"
            android:textColor="@color/card_white"
            android:textSize="12sp"
            app:backgroundTint="@color/red_primary"
            app:cornerRadius="24dp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
